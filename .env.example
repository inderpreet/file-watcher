# Logging Configuration
LOG_LEVEL=INFO
LOG_CONSOLE=true
LOG_FILE=logs/app.log
# LOG_FORMAT=                            # Optional: custom format
# LOG_FORMAT_FILE=                       # Optional: format for file sink
LOG_ROTATION=10 MB
LOG_RETENTION=7 days

# Storage (SQLite)
DATABASE_PATH=data/app.db

# Restic Configuration
RESTIC_REPOSITORY=/path/to/repo
RESTIC_PASSWORD=

# MASTERCHIEF Backup (paths and password from .env)
MASTERCHIEF_SRC=/data/docs,/data/media
MASTERCHIEF_DEST=/backup/repo
MASTERCHIEF_PASSWORD=

# Other restic options
# RESTIC_CACHE_DIR=/tmp/restic-cache
